# Quiet, reproducible installs on every platform (Windows/Linux/macOS).
# fund:    suppress the "N packages are looking for funding" nag.
# loglevel=error: silence npm's warn-level chatter — transitive-dependency
#   deprecations (boolean/glob@7/rimraf@2, all pulled in by electron-builder's
#   own tree and unfixable without breaking its packaging) and the allow-scripts
#   notices. Install scripts are still governed by "allowScripts" in package.json,
#   and check-native.js re-provisions the Electron/esbuild binaries at prestart,
#   so nothing here changes build behavior — only output verbosity.
# To temporarily see all warnings again: npm install --loglevel=warn
fund=false
loglevel=error
